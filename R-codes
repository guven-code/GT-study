# -----------------------------------------
# 1. Kruskal-Wallis test per metagene
# -----------------------------------------
kw_results <- lapply(1:nrow(H), function(k) {
  df <- data.frame(
    activity = H[k, ],           # row = metagene
    cancer   = metadata2$Organ   # must have same length as number of columns
  )
  
  kw <- kruskal.test(activity ~ cancer, data = df)
  
  data.frame(
    Metagene = paste0("Metagene", k),
    H_stat   = kw$statistic,
    P_value  = kw$p.value
  )
}) %>% bind_rows()


kw_results$P_adj <- p.adjust(kw_results$P_value, method = "BH")
print(kw_results)

# Save Kruskal-Wallis p-values as a barplot TIFF
tiff("KruskalWallis_pvalues.tiff", width = 8, height = 5, units = "in", res = 300)
ggplot(kw_results, aes(x = Metagene, y = -log10(P_adj), fill = P_adj < 0.05)) +
  geom_col() +
  geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "red") +
  scale_fill_manual(values = c("grey", "black"), name = "Significant") +
  labs(title = "Kruskal-Wallis test per Metagene (adjusted p-values)",
       y = "-log10(FDR adjusted p-value)", x = "Metagene") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))
dev.off()

# -----------------------------------------
# 2. Dunn post-hoc tests for significant KW metagenes
# -----------------------------------------
dunn_results <- lapply(which(kw_results$P_adj < 0.05), function(k) {
  df <- data.frame(
    activity = H[k, ],
    cancer   = metadata2$Organ
  )
  
  dunn <- dunnTest(activity ~ cancer, data = df, method = "bh")
  
  out <- dunn$res
  out$Metagene <- paste0("Metagene", k)
  out
}) %>% bind_rows()

