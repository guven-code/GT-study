# -----------------------------------------
# 4. Fisher's exact test sensitivity analysis (top N genes)
# -----------------------------------------
cutoffs <- c(50, 100, 200, 1000)

non_gt_genes <- setdiff(rownames(W), gt_genes)

fisher_sensitivity <- lapply(cutoffs, function(n) {
  lapply(1:ncol(W), function(k) {
    top_genes <- names(sort(W[, k], decreasing = TRUE))[1:n]
    
    N_GT     <- sum(top_genes %in% gt_genes)
    N_nonGT  <- n - N_GT
    
    bg_GT    <- length(gt_genes) - N_GT
    bg_nonGT <- length(non_gt_genes) - N_nonGT
    
    tbl <- matrix(c(N_GT, N_nonGT, bg_GT, bg_nonGT), nrow = 2, byrow = TRUE)
    ft <- fisher.test(tbl)
    
    data.frame(
      Metagene  = paste0("Metagene", k),
      Cutoff    = n,
      OddsRatio = ft$estimate,
      P_value   = ft$p.value
    )
  }) %>% bind_rows()
}) %>% bind_rows()

fisher_sensitivity <- fisher_sensitivity %>%
  group_by(Cutoff) %>%
  mutate(P_adj = p.adjust(P_value, method = "BH")) %>%
  ungroup()

# Plot Fisher test p-values (adjusted) per cutoff
tiff("Fisher_sensitivity_pvalues.tiff", width = 10, height = 6, units = "in", res = 300)
ggplot(fisher_sensitivity, aes(x = Metagene, y = -log10(P_adj), fill = Cutoff)) +
  geom_col(position = position_dodge()) +
  geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "red") +
  labs(title = "Fisher's Exact Test p-values by Cutoff",
       y = "-log10(FDR adjusted p-value)",
       x = "Metagene") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))
dev.off()

