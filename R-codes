#5 GO enrichment function (SYMBOL-based)
run_go <- function(gene_symbols, title_tag) {
  
  ego <- enrichGO(
    gene          = gene_symbols,
    OrgDb         = org.Hs.eg.db,
    keyType       = "SYMBOL",
    ont           = "BP",
    pAdjustMethod = "BH",
    qvalueCutoff  = 0.05,
    readable      = TRUE
  )
  
  if (is.null(ego) || nrow(ego@result) == 0) {
    message("No significant GO terms for ", title_tag)
    return(NULL)
